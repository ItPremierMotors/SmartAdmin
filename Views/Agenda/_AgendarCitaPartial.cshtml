@*
    ══════════════════════════════════════════════════════════════
    Vista Parcial: Agendar Nueva Cita
    ──────────────────────────────────────────────────────────────
    Se carga dentro de AppModal desde la Agenda.
    Permite seleccionar cliente (Select2 con busqueda AJAX),
    vehiculo (dependiente del cliente), tipo de servicio,
    fecha, bloque horario y tipo de ingreso.

    Dependencias JS: confirmarAgendar() definida en agenda.js
    Datos de entrada: ViewBag.FechaPreseleccionada, ViewBag.SucursalId
    ══════════════════════════════════════════════════════════════
*@
@{
    var fechaPreseleccionada = ViewBag.FechaPreseleccionada as string;
    var sucursalId = ViewBag.SucursalId as int?;
}

<form id="formAgendarCita">
    <input type="hidden" id="CitaSucursalId" value="@(sucursalId?.ToString() ?? "")" />

    <div class="row">
        @* ── Columna Izquierda: Cliente, Vehiculo y Servicio ── *@
        <div class="col-md-6">
            <div class="mb-3">
                <label for="CitaClienteId" class="form-label">
                    Cliente <span class="text-danger">*</span>
                </label>
                <select class="form-select" id="CitaClienteId" name="ClienteId" required>
                    <option value="">Buscar cliente...</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="CitaVehiculoId" class="form-label">
                    Vehiculo <span class="text-danger">*</span>
                </label>
                <select class="form-select" id="CitaVehiculoId" name="VehiculoId" required>
                    <option value="">Seleccione un cliente primero</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="CitaTipoServicioId" class="form-label">
                    Tipo de Servicio <span class="text-danger">*</span>
                </label>
                <select class="form-select" id="CitaTipoServicioId" name="TipoServicioId" required>
                    <option value="">Cargando...</option>
                </select>
            </div>
        </div>

        @* ── Columna Derecha: Fecha, Bloque Horario, Tipo Ingreso ── *@
        <div class="col-md-6">
            <div class="mb-3">
                <label for="CitaFecha" class="form-label">
                    Fecha <span class="text-danger">*</span>
                </label>
                <input type="date" class="form-control" id="CitaFecha" name="FechaHoraInicio"
                       value="@fechaPreseleccionada" required />
            </div>

            <div class="mb-3">
                <label for="CitaBloqueHorario" class="form-label">Bloque Horario</label>
                <select class="form-select" id="CitaBloqueHorario" name="BloqueHorarioId">
                    <option value="">Cargando bloques...</option>
                </select>
                <div class="alert alert-warning py-1 px-2 mt-1 mb-0 d-none" id="bloqueWarning">
                    <small><i class="fas fa-exclamation-triangle me-1"></i><span id="bloqueWarningText"></span></small>
                </div>
            </div>

            <div class="mb-3" id="horaManualGroup" style="display:none;">
                <label for="CitaHoraManual" class="form-label">Hora Manual</label>
                <input type="time" class="form-control" id="CitaHoraManual" value="08:00" />
            </div>

            <div class="mb-3">
                <label for="CitaTipoIngreso" class="form-label">
                    Tipo de Ingreso <span class="text-danger">*</span>
                </label>
                <select class="form-select" id="CitaTipoIngreso" name="TipoIngreso" required>
                    <option value="1" selected>Cita</option>
                    <option value="2">Walk-In</option>
                    <option value="3">Garantia</option>
                </select>
            </div>
        </div>
    </div>

    @* ── Motivo y Observaciones ── *@
    <div class="mb-3">
        <label for="CitaMotivoVisita" class="form-label">
            Motivo de Visita <span class="text-danger">*</span>
        </label>
        <textarea class="form-control" id="CitaMotivoVisita" name="MotivoVisita" rows="2" required
                  placeholder="Describa el motivo de la visita..."></textarea>
    </div>

    <div class="mb-3">
        <label for="CitaObservaciones" class="form-label">Observaciones</label>
        <textarea class="form-control" id="CitaObservaciones" name="Observaciones" rows="2"
                  placeholder="Notas adicionales (opcional)"></textarea>
    </div>
</form>

@* ── Botones de accion ── *@
<div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i> Cancelar
    </button>
    <button type="button" class="btn btn-primary" id="btnAgendar" onclick="confirmarAgendar()">
        <i class="fas fa-calendar-check me-1"></i> Agendar Cita
    </button>
</div>

@* ══════════════════════════════════════════════════════════════
   Scripts: Inicializacion de Select2, carga de catalogos
   y logica de bloques horarios.
   ══════════════════════════════════════════════════════════════ *@
<script>
    // Cache de tipos de servicio para filtrado por tipo de ingreso
    window._tiposServicioData = [];
    // Indica si hay bloques horarios configurados para la fecha
    window._hayBloquesActivos = false;

    $(document).ready(function () {
        initClienteSelect();
        cargarTiposServicio();
        cargarBloquesDisponibles();

        // Recargar bloques al cambiar fecha
        $('#CitaFecha').on('change', function () {
            cargarBloquesDisponibles();
        });

        // Opcion "hora manual" al final del select de bloques
        $('#CitaBloqueHorario').on('change', function () {
            if ($(this).val() === '__manual__') {
                $('#horaManualGroup').show();
                $(this).val('');
            } else {
                $('#horaManualGroup').hide();
            }
        });

        // Filtrar servicios y visibilidad de hora manual segun tipo de ingreso
        $('#CitaTipoIngreso').on('change', function () {
            filtrarTiposServicio();
            actualizarVisibilidadHoraManual();
        });
    });

    // ── Select2: Busqueda de clientes via AJAX ──
    function initClienteSelect() {
        $('#CitaClienteId').select2({
            dropdownParent: $('.modal'),
            theme: 'bootstrap-5',
            placeholder: 'Buscar cliente...',
            allowClear: true,
            minimumInputLength: 2,
            language: { inputTooShort: () => 'Escriba al menos 2 caracteres...' },
            ajax: {
                url: '@Url.Action("Search", "Clientes")',
                dataType: 'json',
                delay: 300,
                data: function (params) { return { term: params.term }; },
                processResults: function (data) {
                    if (data.success && data.data) {
                        return {
                            results: data.data.map(c => ({
                                id: c.clienteId,
                                text: c.nombreCompleto + ' (' + (c.dni || c.rtn || c.telefono) + ')'
                            }))
                        };
                    }
                    return { results: [] };
                }
            }
        }).on('change', function () {
            cargarVehiculosCliente($(this).val());
        });
    }

    // ── Carga vehiculos asociados al cliente seleccionado ──
    function cargarVehiculosCliente(clienteId) {
        const $sel = $('#CitaVehiculoId');
        $sel.empty().append('<option value="">Cargando...</option>');

        if (!clienteId) {
            $sel.empty().append('<option value="">Seleccione un cliente primero</option>');
            return;
        }

        $.get('@Url.Action("GetByCliente", "Inventario")', { clienteId: clienteId }, function (response) {
            $sel.empty().append('<option value="">Seleccione vehiculo...</option>');
            if (response.success && response.data && response.data.length > 0) {
                response.data.forEach(v => {
                    const desc = v.descripcionCompleta || (v.marcaNombre + ' ' + v.modeloNombre + ' ' + v.anio);
                    const placa = v.placa ? ` | Placa: ${v.placa}` : '';
                    const vin = v.vin ? ` | VIN: ...${v.vin.slice(-6)}` : '';
                    $sel.append(`<option value="${v.vehiculoId}">${desc}${placa}${vin}</option>`);
                });
            } else {
                $sel.empty().append('<option value="">No se encontraron vehiculos para este cliente</option>');
            }
        }).fail(function () {
            $sel.empty().append('<option value="">Error al buscar vehiculos</option>');
        });
    }

    // ── Carga catalogo de tipos de servicio ──
    function cargarTiposServicio() {
        $.get('@Url.Action("GetAll", "TiposServicio")', function (response) {
            if (response.success && response.data) {
                window._tiposServicioData = response.data;
                filtrarTiposServicio();
            }
        });
    }

    // ── Filtra tipos de servicio segun el tipo de ingreso seleccionado ──
    // Walk-In: solo servicios con PermiteWalkIn=true y RequiereCita=false
    function filtrarTiposServicio() {
        const tipoIngreso = parseInt($('#CitaTipoIngreso').val());
        const $sel = $('#CitaTipoServicioId');
        $sel.empty().append('<option value="">Seleccione tipo de servicio...</option>');

        if (!window._tiposServicioData) return;

        let count = 0;
        window._tiposServicioData.forEach(ts => {
            if (tipoIngreso === 2 && (!ts.permiteWalkIn || ts.requiereCita)) return;
            $sel.append(`<option value="${ts.tipoServicioId}">${ts.nombre} (${ts.duracionFormateada})</option>`);
            count++;
        });

        if (count === 0 && tipoIngreso === 2) {
            $sel.empty().append('<option value="">No hay servicios disponibles para Walk-In</option>');
        }
    }

    // ── Carga bloques horarios disponibles para la fecha seleccionada ──
    function cargarBloquesDisponibles() {
        const fecha = $('#CitaFecha').val();
        const params = { fecha: fecha };
        const sId = $('#CitaSucursalId').val();
        if (sId) params.sucursalId = sId;

        $.get('@Url.Action("GetBloquesDisponibles", "Agenda")', params, function (response) {
            const $sel = $('#CitaBloqueHorario');
            $sel.empty();
            if (response.success && response.data && response.data.length > 0) {
                window._hayBloquesActivos = true;
                response.data.forEach(b => {
                    const label = b.horaInicioFormateada + ' - ' + b.horaFinFormateada +
                        ' (' + b.espaciosDisponibles + ' disponibles) [' + b.tipoBloqueNombre + ']';
                    $sel.append(`<option value="${b.bloqueId}" data-hora="${b.horaInicio}">${label}</option>`);
                });
            } else {
                window._hayBloquesActivos = false;
                $sel.append('<option value="">Sin bloques configurados</option>');
            }
            actualizarVisibilidadHoraManual();
        });
    }

    // ── Controla visibilidad de hora manual y validacion de bloques ──
    // Reglas:
    //   - Con bloques activos: obligatorio seleccionar bloque (todos los tipos)
    //   - Walk-In sin bloques: permite hora manual
    //   - Cita/Garantia sin bloques: deshabilita el boton de agendar
    function actualizarVisibilidadHoraManual() {
        const tipoIngreso = parseInt($('#CitaTipoIngreso').val());
        const $warning = $('#bloqueWarning');
        const $warningText = $('#bloqueWarningText');

        if (window._hayBloquesActivos) {
            $('#horaManualGroup').hide();
            $warning.addClass('d-none');
            $('#btnAgendar').prop('disabled', false);
        } else if (tipoIngreso === 2) {
            $('#horaManualGroup').show();
            $warning.addClass('d-none');
            $('#btnAgendar').prop('disabled', false);
        } else {
            $('#horaManualGroup').hide();
            $warningText.text('No hay bloques configurados para esta fecha. Configure bloques o cambie a Walk-In.');
            $warning.removeClass('d-none');
            $('#btnAgendar').prop('disabled', true);
        }
    }
</script>
