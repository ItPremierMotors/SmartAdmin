@model SmartAdmin.Models.Account.LoginViewModel
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_BaseLayout.cshtml";
}

@section styles
{

}

<section class="hero-section position-relative overflow-hidden">
    <div class="container" style="position: relative; z-index: 1;">
        <div class="row justify-content-center">
            <div class="col-11 col-md-8 col-lg-6 col-xl-4">
                <div class="text-center mb-4">
                    <h2 class="text-white fw-bold">Premier Motors</h2>
                </div>
                <div class="login-card p-4 p-md-6 bg-dark bg-opacity-50 translucent-dark rounded-4" id="regular-login">
                    <p class="text-center text-white opacity-50 mb-4">Inicia sesión para continuar</p>
                    <form asp-action="Login" asp-controller="Auth" method="post">

                        @* Errores generales (usuario/clave incorrectos, etc.) *@
                        <div class="text-center mb-3">
                            @Html.ValidationSummary(true, null, new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label" asp-for=@Model.Email></label>
                            <input asp-for=@Model.Email
                                   type="email"
                                   class="form-control form-control-lg text-white bg-dark border-light border-opacity-25 bg-opacity-25"
                                    />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" asp-for=@Model.Password></label>
                            <div class="input-group">
                                <input asp-for="Password"
                                       type="password"
                                     class="form-control form-control-lg text-white bg-dark border-light border-opacity-25 bg-opacity-25"
                                     required=""  />
                            </div>
                        </div>
                        <div class="d-grid mb-3">
                            <button class="btn btn-primary btn-lg bg-primary bg-opacity-75" type="submit">
                                Iniciar sesión
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div id="net"></div>
</section>

@section scripts
{
    <script src="~/plugins/bootstrap/bootstrap.bundle.min.js"></script>
    <script src="~/plugins/three/three.min.js"></script>
    <script src="~/plugins/vanta/vanta.halo.min.js"></script>
    <script src="~/plugins/vanta/vanta.net.min.js"></script>
    <script src="~/scripts/pages/auth-animation.js"></script>
}
