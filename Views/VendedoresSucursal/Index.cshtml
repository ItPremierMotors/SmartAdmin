@{
    ViewData["Title"] = "Vendedores por Sucursal";
}

<div class="container-fluid">
    <!-- ══════════════════════════════════════════════════════════════
         Gestión de asignaciones vendedor ↔ sucursal
         Un vendedor puede atender varias sucursales
         La separación por línea de negocio la hace la sucursal, no el vendedor
    ══════════════════════════════════════════════════════════════ -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0"><i class="fas fa-user-cog me-2"></i>@ViewData["Title"]</h1>
    </div>

    <div class="row g-4">
        <!-- Panel izquierdo: selección de sucursal y asignación -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header"><i class="fas fa-building me-1"></i>Sucursal</div>
                <div class="card-body">
                    <select class="form-select mb-3" id="selectSucursal">
                        <option value="">Seleccione sucursal...</option>
                    </select>

                    <!-- Formulario asignar -->
                    <div id="formAsignar" class="d-none">
                        <hr />
                        <h6><i class="fas fa-plus me-1"></i>Asignar Vendedor</h6>
                        <select class="form-select mb-2" id="selectVendedor">
                            <option value="">Seleccione vendedor...</option>
                        </select>
                        <button class="btn btn-primary btn-sm w-100" id="btnAsignar" onclick="asignar()">
                            <i class="fas fa-link me-1"></i>Asignar a Sucursal
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel derecho: lista de vendedores asignados -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-users me-1"></i>Vendedores Asignados</span>
                    <span class="badge bg-primary" id="countVendedores">0</span>
                </div>
                <div class="card-body">
                    <div id="loading" class="text-center py-3 d-none">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </div>
                    <div id="listaVendedores">
                        <p class="text-muted text-center">Seleccione una sucursal para ver sus vendedores</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const URLS = {
        getBySucursal: '@Url.Action("GetBySucursal")',
        asignar:       '@Url.Action("Asignar")',
        activar:       '@Url.Action("Activar")',
        desactivar:    '@Url.Action("Desactivar")',
        sucursales:    '@Url.Action("GetSucursales")',
        vendedores:    '@Url.Action("GetVendedores")'
    };

    $(document).ready(function () {
        cargarCatalogos();
        $('#selectSucursal').on('change', function () {
            const id = $(this).val();
            if (id) { cargarVendedores(id); $('#formAsignar').removeClass('d-none'); }
            else { $('#formAsignar').addClass('d-none'); $('#listaVendedores').html('<p class="text-muted text-center">Seleccione una sucursal</p>'); }
        });
    });

    function cargarCatalogos() {
        $.get(URLS.sucursales, r => {
            if (r.success && r.data) r.data.forEach(s => $('#selectSucursal').append(`<option value="${s.id}">${s.nombre}</option>`));
        });
        $.get(URLS.vendedores, r => {
            if (r.success && r.data) r.data.forEach(u => $('#selectVendedor').append(`<option value="${u.id}">${u.nombreCompleto}</option>`));
        });
    }

    function cargarVendedores(sucursalId) {
        $('#loading').removeClass('d-none');
        $.get(URLS.getBySucursal, { sucursalId }, function (r) {
            $('#loading').addClass('d-none');
            if (!r.success) { Toast.error(r.message); return; }
            renderVendedores(r.data || []);
        }).fail(() => { $('#loading').addClass('d-none'); Toast.error('Error al cargar'); });
    }

    function renderVendedores(items) {
        $('#countVendedores').text(items.length);
        if (!items.length) {
            $('#listaVendedores').html('<p class="text-muted text-center">No hay vendedores asignados a esta sucursal</p>');
            return;
        }
        const html = `
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Vendedor</th><th class="text-center">Estado</th><th class="text-center">Acciones</th></tr>
                    </thead>
                    <tbody>
                        ${items.map(v => `
                            <tr>
                                <td><strong>${v.vendedorNombre}</strong></td>
                                <td class="text-center">
                                    <span class="badge bg-${v.estaActivo ? 'success' : 'secondary'}">${v.estaActivo ? 'Activo' : 'Inactivo'}</span>
                                </td>
                                <td class="text-center">
                                    ${v.estaActivo
                                        ? `<button class="btn btn-sm btn-outline-danger" onclick="desactivar(${v.vendedorSucursalId})" title="Desactivar"><i class="fas fa-toggle-off"></i></button>`
                                        : `<button class="btn btn-sm btn-outline-success" onclick="activar(${v.vendedorSucursalId})" title="Activar"><i class="fas fa-toggle-on"></i></button>`}
                                </td>
                            </tr>`).join('')}
                    </tbody>
                </table>
            </div>`;
        $('#listaVendedores').html(html);
    }

    function asignar() {
        const sucursalId = parseInt($('#selectSucursal').val());
        const vendedorId = $('#selectVendedor').val();
        if (!sucursalId || !vendedorId) { Toast.error('Seleccione sucursal y vendedor'); return; }
        enviarForm('btnAsignar', URLS.asignar, { vendedorId, sucursalId }, () => {
            Toast.success('Vendedor asignado');
            $('#selectVendedor').val('');
            cargarVendedores(sucursalId);
        });
    }

    function activar(id) {
        if (!confirm('¿Activar este vendedor en la sucursal?')) return;
        postSimple(URLS.activar, id, () => { Toast.success('Vendedor activado'); cargarVendedores($('#selectSucursal').val()); });
    }

    function desactivar(id) {
        if (!confirm('¿Desactivar este vendedor de la sucursal?')) return;
        postSimple(URLS.desactivar, id, () => { Toast.success('Vendedor desactivado'); cargarVendedores($('#selectSucursal').val()); });
    }

    // ═══ HELPERS ═══
    function enviarForm(btnId, url, data, onSuccess) {
        const btn = document.getElementById(btnId);
        const orig = btn.innerHTML;
        $.ajax({
            url, type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            beforeSend: () => $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>'),
            success: r => { if (r.success) onSuccess(r); else Toast.error(r.message || 'Error'); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error'),
            complete: () => $(btn).prop('disabled', false).html(orig)
        });
    }

    function postSimple(url, data, onSuccess) {
        $.ajax({
            url, type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            success: r => { if (r.success) onSuccess(r); else Toast.error(r.message || 'Error'); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error')
        });
    }
</script>
}
