@model SmartAdmin.Models.Crm.CerrarOportunidadViewModel
@{
    var tipo = ViewBag.TipoCierre as string;
    var esGanada = tipo == "ganada";
    var label = tipo switch { "ganada" => "Ganada", "perdida" => "Perdida", _ => "Cancelada" };
    var btnColor = tipo switch { "ganada" => "success", "perdida" => "danger", _ => "secondary" };
}
<div>
    <p>¿Está seguro de cerrar esta oportunidad como <strong>@label</strong>?</p>
    @if (esGanada)
    {
        <!-- Ganada: solo requiere cotización aceptada, no pide motivo -->
        <div class="alert alert-info small mb-3">
            <i class="fas fa-info-circle me-1"></i>Se requiere al menos una cotización aceptada para cerrar como ganada.
        </div>
    }
    else
    {
        <!-- Perdida/Cancelar: motivo obligatorio -->
        <div class="mb-3">
            <label class="form-label">Motivo <span class="text-danger">*</span></label>
            <textarea class="form-control" id="MotivoResultado" rows="3" maxlength="500" required
                      placeholder="Indique el motivo..."></textarea>
        </div>
    }
    <hr />
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" onclick="AppModal.close()">Cancelar</button>
        <button type="button" class="btn btn-@btnColor" id="btnCerrar" onclick="cerrarOportunidad('@tipo')">
            <i class="fas fa-flag-checkered me-1"></i> Confirmar
        </button>
    </div>
</div>
