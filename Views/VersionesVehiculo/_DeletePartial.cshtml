@* ══════════════════════════════════════════════════════════════
   Vista:        VersionesVehiculo/_DeletePartial
   Descripcion:  Vista parcial de confirmacion para eliminar una Version
                 de Vehiculo. Muestra advertencia con icono, alerta de
                 que la version se marcara como inactiva, y botones
                 Cancelar / Eliminar.
                 El id de la version se pasa via ViewBag.VersionId.
   Model:        Sin modelo fuerte – usa ViewBag.VersionId
   JS Deps:      jQuery (el boton Eliminar invoca confirmarEliminar() en Index)
   ══════════════════════════════════════════════════════════════ *@

<div class="text-center p-4">
    @* Campo oculto con el id de la version a eliminar *@
    <input type="hidden" id="deleteId" value="@ViewBag.VersionId" />

    @* ── Icono de advertencia ── *@
    <div class="mb-4">
        <i class="fas fa-exclamation-triangle text-warning" style="font-size: 4rem;"></i>
    </div>

    @* ── Mensaje de confirmacion ── *@
    <h5 class="mb-3">¿Esta seguro de eliminar esta version?</h5>

    @* ── Alerta sobre el efecto de la eliminacion ── *@
    <div class="alert alert-warning mb-4" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        <strong>Advertencia:</strong> Esta accion marcara la version como inactiva en el sistema.
    </div>

    @* ── Botones de accion del modal ── *@
    <div class="d-flex justify-content-center gap-2 mt-4">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="fas fa-times me-1"></i> Cancelar
        </button>
        <button type="button" class="btn btn-danger" id="btnEliminarVersion" onclick="confirmarEliminar()">
            <i class="fas fa-trash me-1"></i> Si, Eliminar
        </button>
    </div>
</div>
