@* ══════════════════════════════════════════════════════════════
   Vista:        VersionesVehiculo/_DetailPartial
   Descripcion:  Vista parcial de solo lectura que muestra el detalle
                 completo de una Version de Vehiculo: informacion principal
                 (nombre, codigo, marca, modelo), motor y rendimiento
                 (motor, cilindraje, potencia, torque, combustible,
                 traccion), caracteristicas del vehiculo (transmision,
                 anio, puertas, pasajeros, precio) y caracteristicas
                 principales (texto libre).
                 Se carga dentro de un modal via AppModal.
   Model:        SmartAdmin.Models.Catalogo.VersionVehiculo.VersionVehiculoViewModel
   JS Deps:      Ninguna (vista de solo lectura)
   ══════════════════════════════════════════════════════════════ *@
@model SmartAdmin.Models.Catalogo.VersionVehiculo.VersionVehiculoViewModel

<div class="container-fluid">
    <div class="row g-3">
        @* ── Informacion Principal (nombre, codigo, marca, modelo) ── *@
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="mb-1">
                                <i class="fas fa-car text-primary me-2"></i>@Model.DescripcionCompleta
                            </h5>
                            <p class="text-muted mb-0">@Model.MarcaModelo</p>
                        </div>
                        <span class="badge bg-secondary fs-6">@Model.Codigo</span>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block">Nombre</small>
                                <strong>@Model.Nombre</strong>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block">Marca</small>
                                <strong>@(Model.MarcaNombre ?? "N/A")</strong>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block">Modelo</small>
                                <strong>@(Model.ModeloNombre ?? "N/A")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Motor y Rendimiento ── *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">
                        <i class="fas fa-cog me-2"></i>Motor y Rendimiento
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-6">
                            <small class="text-muted d-block">Motor</small>
                            <strong>@(Model.Motor ?? "No especificado")</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Cilindraje</small>
                            <strong>@(Model.Cilindraje != null ? $"{Model.Cilindraje} L" : "N/A")</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Potencia</small>
                            <strong>@(Model.PotenciaHp != null ? $"{Model.PotenciaHp} HP" : "N/A")</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Torque</small>
                            <strong>@(Model.TorqueNm != null ? $"{Model.TorqueNm} Nm" : "N/A")</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Tipo de Combustible</small>
                            <strong>@Model.TipoCombustibleNombre</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Traccion</small>
                            <strong>@Model.TraccionNombre</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Caracteristicas del Vehiculo ── *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0">
                        <i class="fas fa-car-side me-2"></i>Caracteristicas del Vehiculo
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-6">
                            <small class="text-muted d-block">Transmision</small>
                            <strong>@Model.TransmisionNombre</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Anio Version</small>
                            <strong>@(Model.AnioVersion?.ToString() ?? "N/A")</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Numero de Puertas</small>
                            <strong>@(Model.NumPuertas?.ToString() ?? "N/A")</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Numero de Pasajeros</small>
                            <strong>@(Model.NumPasajeros?.ToString() ?? "N/A")</strong>
                        </div>
                        <div class="col-12">
                            <small class="text-muted d-block">Precio Base</small>
                            <strong class="text-success fs-5">
                                @(Model.PrecioBase != null ? $"${Model.PrecioBase:N2}" : "N/A")
                            </strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Caracteristicas Principales (texto libre, si existe) ── *@
        @if (!string.IsNullOrEmpty(Model.CaracteristicasPrincipales))
        {
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-list-ul me-2"></i>Caracteristicas Principales
                        </h6>
                    </div>
                    <div class="card-body">
                        <p class="mb-0">@Model.CaracteristicasPrincipales</p>
                    </div>
                </div>
            </div>
        }

        @* ── Boton cerrar modal ── *@
        <div class="col-12 d-flex justify-content-end mt-2">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                <i class="fas fa-times me-1"></i> Cerrar
            </button>
        </div>
    </div>
</div>
