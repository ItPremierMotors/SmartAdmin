@model SmartAdmin.Models.Crm.EditLeadViewModel
<form id="formEditarLead">
    <input type="hidden" id="LeadId" value="@Model.LeadId" />
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Nombre Completo <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="NombreCompleto" value="@Model.NombreCompleto" required maxlength="150" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Teléfono</label>
            <input type="text" class="form-control" id="Telefono" value="@Model.Telefono" maxlength="20" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Correo Electrónico</label>
            <input type="email" class="form-control" id="Email" value="@Model.Email" maxlength="100" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Empresa</label>
            <input type="text" class="form-control" id="Empresa" value="@Model.Empresa" maxlength="150" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Ciudad</label>
            <input type="text" class="form-control" id="Ciudad" value="@Model.Ciudad" maxlength="100" />
        </div>
        <div class="col-md-12">
            <label class="form-label">Detalle Origen</label>
            <input type="text" class="form-control" id="DetalleOrigen" value="@Model.DetalleOrigen" maxlength="250" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Vehículo de Interés</label>
            <input type="text" class="form-control" id="VehiculoInteres" value="@Model.VehiculoInteres" maxlength="200" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Presupuesto Estimado</label>
            <input type="number" class="form-control" id="PresupuestoEstimado" value="@Model.PresupuestoEstimado" step="0.01" min="0" />
        </div>
        <input type="hidden" id="ClienteId" value="@Model.ClienteId" />
    </div>
    <hr />
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" onclick="AppModal.close()">Cancelar</button>
        <button type="button" class="btn btn-primary" id="btnActualizarLead" onclick="actualizarLead()">
            <i class="fas fa-save me-1"></i> Actualizar
        </button>
    </div>
</form>
