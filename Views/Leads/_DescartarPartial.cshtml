@model SmartAdmin.Models.Crm.DescartarLeadViewModel
<form id="formDescartarLead">
    <input type="hidden" id="DescartarLeadId" value="@Model.LeadId" />
    <div class="mb-3">
        <label class="form-label">Motivo del descarte <span class="text-danger">*</span></label>
        <textarea class="form-control" id="Motivo" rows="3" required maxlength="500" placeholder="Indique el motivo..."></textarea>
    </div>
    <hr />
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" onclick="AppModal.close()">Cancelar</button>
        <button type="button" class="btn btn-danger" id="btnDescartarLead" onclick="descartarLead()">
            <i class="fas fa-times me-1"></i> Descartar
        </button>
    </div>
</form>
