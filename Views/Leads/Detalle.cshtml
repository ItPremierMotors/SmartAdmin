@model SmartAdmin.Models.Crm.LeadViewModel
@{
    ViewData["Title"] = $"Lead {Model.CodigoLead}";
    var estadoColor = Model.Estado switch { 1 => "info", 2 => "primary", 3 => "success", 5 => "danger", _ => "secondary" };
    var origenes = new Dictionary<int,string> { {1,"Web"},{2,"WhatsApp"},{3,"Llamada"},{4,"Showroom"},{5,"Referido"},{6,"Redes Sociales"},{7,"Evento"},{8,"Recompra"},{99,"Otro"} };
}
<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary me-2">
                <i class="fas fa-arrow-left"></i>
            </a>
            <span class="h3 mb-0">@Model.CodigoLead</span>
            <span class="badge bg-@estadoColor ms-2">@Model.EstadoNombre</span>
        </div>
        <div class="btn-group">
            @if (Model.Estado == 2 && User.TienePermiso("Lead.Editar"))
            {
                <button class="btn btn-success btn-sm" onclick="calificarLead()">
                    <i class="fas fa-check me-1"></i>Calificar
                </button>
            }
            @if (Model.Estado <= 3 && User.TienePermiso("Lead.Editar"))
            {
                <button class="btn btn-danger btn-sm" onclick="abrirDescartar()">
                    <i class="fas fa-times me-1"></i>Descartar
                </button>
            }
            @if (Model.Estado <= 3 && User.TienePermiso("Lead.Asignar"))
            {
                <button class="btn btn-warning btn-sm" onclick="abrirAsignarVendedor()">
                    <i class="fas fa-user-plus me-1"></i>Asignar Vendedor
                </button>
            }
        </div>
    </div>

    <!-- Info general -->
    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <small class="text-muted d-block">Nombre</small>
                            <strong>@Model.NombreCompleto</strong>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Teléfono</small>
                            @(Model.Telefono ?? "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Email</small>
                            @(Model.Email ?? "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Empresa</small>
                            @(Model.Empresa ?? "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Ciudad</small>
                            @(Model.Ciudad ?? "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Origen</small>
                            @(origenes.GetValueOrDefault(Model.Origen, "—"))
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Detalle Origen</small>
                            @(Model.DetalleOrigen ?? "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Vendedor</small>
                            @(Model.VendedorNombre ?? "Sin asignar")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Sucursal</small>
                            @(Model.SucursalNombre ?? "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Vehículo de Interés</small>
                            @(Model.VehiculoInteres ?? "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Presupuesto Estimado</small>
                            @(Model.PresupuestoEstimado.HasValue ? Model.PresupuestoEstimado.Value.ToString("C2") : "—")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Fecha Ingreso</small>
                            @Model.FechaIngreso.ToString("dd/MM/yyyy")
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Primer Contacto</small>
                            @(Model.FechaPrimeraRespuesta.HasValue ? Model.FechaPrimeraRespuesta.Value.ToString("dd/MM/yyyy") : "Sin contactar")
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-header"><i class="fas fa-chart-bar me-2"></i>Resumen</div>
                <div class="card-body d-flex align-items-center">
                    <div class="d-flex justify-content-around text-center w-100">
                        <div>
                            <h4 class="mb-0">@Model.CantidadActividades</h4>
                            <small class="text-muted">Actividades</small>
                        </div>
                        <div>
                            <h4 class="mb-0">@Model.CantidadOportunidades</h4>
                            <small class="text-muted">Oportunidades</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs" id="detalleTabs">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#tabActividades">
                <i class="fas fa-tasks me-1"></i>Actividades
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tabNotas">
                <i class="fas fa-sticky-note me-1"></i>Notas
            </a>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-3 bg-white">
        <!-- Tab Actividades -->
        <div class="tab-pane fade show active" id="tabActividades">
            @if (Model.Estado < 5)
            {
                <div class="d-flex justify-content-end mb-2">
                    <button class="btn btn-sm btn-primary" onclick="abrirModalActividad()">
                        <i class="fas fa-plus me-1"></i>Nueva Actividad
                    </button>
                </div>
            }
            <div id="listaActividades"></div>
        </div>

        <!-- Tab Notas -->
        <div class="tab-pane fade" id="tabNotas">
            <div class="d-flex justify-content-end mb-2">
                <button class="btn btn-sm btn-primary" onclick="abrirModalNota()">
                    <i class="fas fa-plus me-1"></i>Nueva Nota
                </button>
            </div>
            <div id="listaNotas"></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const LEAD_ID = @Model.LeadId;
    const ESTADO = @Model.Estado;
    const URLS = {
        getActividades:          '@Url.Action("GetActividades")',
        actividadPartial:        '@Url.Action("ActividadPartial")',
        completarPartial:        '@Url.Action("CompletarActividadPartial")',
        createActividad:         '@Url.Action("CreateActividad")',
        completarActividad:      '@Url.Action("CompletarActividad")',
        cancelarActividad:       '@Url.Action("CancelarActividad")',
        getNotas:                '@Url.Action("GetNotas")',
        notaPartial:             '@Url.Action("NotaPartial")',
        createNota:              '@Url.Action("CreateNota")',
        deleteNota:              '@Url.Action("DeleteNota")',
        calificar:               '@Url.Action("Calificar")',
        descartarPartial:        '@Url.Action("DescartarPartial")',
        descartar:               '@Url.Action("Descartar")',
        asignarVendedorPartial:  '@Url.Action("AsignarVendedorPartial")',
        asignarVendedor:         '@Url.Action("AsignarVendedor")'
    };

    const TIPO_ACTIVIDAD = { 1:'Llamada', 2:'WhatsApp', 3:'Email', 4:'Visita', 5:'Test Drive', 6:'Reunión', 7:'Seguimiento Auto' };
    const ESTADO_ACTIVIDAD = { 1:'Pendiente', 2:'Completada', 3:'Cancelada', 4:'Vencida' };
    const ESTADO_ACTIVIDAD_COLOR = { 1:'warning', 2:'success', 3:'danger', 4:'secondary' };

    $(document).ready(function () {
        cargarActividades();
        cargarNotas();
    });

    // ═══ ACTIVIDADES ═══
    function cargarActividades() {
        $.get(URLS.getActividades, { leadId: LEAD_ID }, function (r) {
            if (r.success && r.data) renderActividades(r.data);
            else $('#listaActividades').html('<p class="text-muted text-center">No hay actividades registradas</p>');
        });
    }

    function renderActividades(items) {
        if (items.length === 0) {
            $('#listaActividades').html('<p class="text-muted text-center">No hay actividades registradas</p>');
            return;
        }
        let html = '<div class="list-group">';
        items.forEach(a => {
            html += `
                <div class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <div>
                            <strong>${a.asunto}</strong>
                            <span class="badge bg-${ESTADO_ACTIVIDAD_COLOR[a.estado]} ms-1">${ESTADO_ACTIVIDAD[a.estado]}</span>
                            <span class="badge bg-light text-dark ms-1">${TIPO_ACTIVIDAD[a.tipo] || a.tipo}</span>
                        </div>
                        <div class="btn-group btn-group-sm">
                            ${a.estado === 1 ? `
                                <button class="btn btn-outline-success" onclick="abrirCompletarActividad(${a.actividadCrmId})" title="Completar"><i class="fas fa-check"></i></button>
                                <button class="btn btn-outline-danger" onclick="cancelarActividad(${a.actividadCrmId})" title="Cancelar"><i class="fas fa-times"></i></button>
                            ` : ''}
                        </div>
                    </div>
                    <small class="text-muted">${a.descripcion || ''}</small>
                    <div class="mt-1">
                        <small class="text-muted">
                            ${a.fechaProgramada ? '<i class="fas fa-calendar me-1"></i>' + new Date(a.fechaProgramada).toLocaleDateString('es-HN') : ''}
                            | ${a.realizadaPorNombre}
                        </small>
                        ${a.resultado ? `<br/><small class="text-success"><i class="fas fa-check-circle me-1"></i>${a.resultado}</small>` : ''}
                    </div>
                </div>`;
        });
        html += '</div>';
        $('#listaActividades').html(html);
    }

    function abrirModalActividad() {
        AppModal.open({ title: '<i class="fas fa-plus me-2"></i>Nueva Actividad', url: URLS.actividadPartial, data: { leadId: LEAD_ID }, size: 'lg' });
    }

    function abrirCompletarActividad(id) {
        AppModal.open({ title: '<i class="fas fa-check me-2"></i>Completar Actividad', url: URLS.completarPartial, data: { id }, size: 'md' });
    }

    function guardarActividad() {
        const form = document.getElementById('formActividad');
        const btn = document.getElementById('btnGuardarActividad');
        const btnOriginal = btn.innerHTML;
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const data = {
            leadId: LEAD_ID,
            tipo: parseInt($('#Tipo').val()),
            direccion: parseInt($('#Direccion').val()),
            asunto: $('#Asunto').val().trim(),
            descripcion: $('#Descripcion').val()?.trim() || null,
            fechaProgramada: $('#FechaProgramada').val() || null
        };
        $.ajax({
            url: URLS.createActividad, type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            beforeSend: () => $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>'),
            success: r => { if (r.success) { AppModal.close(); cargarActividades(); Toast.success('Actividad creada'); } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error'),
            complete: () => $(btn).prop('disabled', false).html(btnOriginal)
        });
    }

    function completarActividad() {
        const form = document.getElementById('formCompletarActividad');
        const btn = document.getElementById('btnCompletarActividad');
        const btnOriginal = btn.innerHTML;
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const data = {
            actividadCrmId: parseInt($('#ActividadCrmId').val()),
            resultado: $('#Resultado').val().trim(),
            duracionMinutos: $('#DuracionMinutos').val() ? parseInt($('#DuracionMinutos').val()) : null,
            proximoContacto: $('#ProximoContacto').val() || null
        };
        $.ajax({
            url: URLS.completarActividad, type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            beforeSend: () => $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>'),
            success: r => { if (r.success) { AppModal.close(); cargarActividades(); Toast.success('Actividad completada'); } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error'),
            complete: () => $(btn).prop('disabled', false).html(btnOriginal)
        });
    }

    function cancelarActividad(id) {
        if (!confirm('¿Cancelar esta actividad?')) return;
        $.ajax({
            url: URLS.cancelarActividad, type: 'POST', contentType: 'application/json', data: JSON.stringify(id),
            success: r => { if (r.success) { cargarActividades(); Toast.success('Actividad cancelada'); } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error')
        });
    }

    // ═══ NOTAS ═══
    function cargarNotas() {
        $.get(URLS.getNotas, { leadId: LEAD_ID }, function (r) {
            if (r.success && r.data) renderNotas(r.data);
            else $('#listaNotas').html('<p class="text-muted text-center">No hay notas</p>');
        });
    }

    function renderNotas(items) {
        if (items.length === 0) { $('#listaNotas').html('<p class="text-muted text-center">No hay notas</p>'); return; }
        let html = '';
        items.forEach(n => {
            html += `
                <div class="card mb-2">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between">
                            <div>
                                <strong>${n.autorNombre}</strong>
                                <small class="text-muted ms-2">${new Date(n.fechaCreacion).toLocaleString('es-HN')}</small>
                                ${n.esPrivada ? '<span class="badge bg-warning ms-1">Privada</span>' : ''}
                            </div>
                            <button class="btn btn-sm btn-outline-danger" onclick="eliminarNota(${n.notaCrmId})">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                        <p class="mb-0 mt-1">${n.contenido}</p>
                    </div>
                </div>`;
        });
        $('#listaNotas').html(html);
    }

    function abrirModalNota() {
        AppModal.open({ title: '<i class="fas fa-sticky-note me-2"></i>Nueva Nota', url: URLS.notaPartial, data: { leadId: LEAD_ID }, size: 'md' });
    }

    function guardarNota() {
        const form = document.getElementById('formNota');
        const btn = document.getElementById('btnGuardarNota');
        const btnOriginal = btn.innerHTML;
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const data = {
            leadId: LEAD_ID,
            contenido: $('#Contenido').val().trim(),
            esPrivada: $('#EsPrivada').is(':checked')
        };
        $.ajax({
            url: URLS.createNota, type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            beforeSend: () => $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>'),
            success: r => { if (r.success) { AppModal.close(); cargarNotas(); Toast.success('Nota creada'); } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error'),
            complete: () => $(btn).prop('disabled', false).html(btnOriginal)
        });
    }

    function eliminarNota(id) {
        if (!confirm('¿Eliminar esta nota?')) return;
        $.ajax({
            url: URLS.deleteNota, type: 'POST', contentType: 'application/json', data: JSON.stringify(id),
            success: r => { if (r.success) { cargarNotas(); Toast.success('Nota eliminada'); } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error')
        });
    }

    // ═══ ACCIONES DEL LEAD ═══
    function calificarLead() {
        if (!confirm('¿Calificar este lead? Pasará a estado Calificado.')) return;
        $.ajax({
            url: URLS.calificar, type: 'POST', contentType: 'application/json',
            data: JSON.stringify({ leadId: LEAD_ID }),
            success: r => { if (r.success) { Toast.success('Lead calificado'); location.reload(); } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error')
        });
    }

    function abrirDescartar() {
        AppModal.open({ title: '<i class="fas fa-times me-2"></i>Descartar Lead', url: URLS.descartarPartial, data: { id: LEAD_ID }, size: 'md' });
    }

    function descartarLead() {
        const form = document.getElementById('formDescartar');
        const btn = document.getElementById('btnDescartar');
        const btnOriginal = btn.innerHTML;
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const data = { leadId: LEAD_ID, motivo: $('#Motivo').val().trim() };
        $.ajax({
            url: URLS.descartar, type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            beforeSend: () => $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>'),
            success: r => { if (r.success) { Toast.success('Lead descartado'); window.location.href = '@Url.Action("Index")'; } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error'),
            complete: () => $(btn).prop('disabled', false).html(btnOriginal)
        });
    }

    function abrirAsignarVendedor() {
        AppModal.open({ title: '<i class="fas fa-user-plus me-2"></i>Asignar Vendedor', url: URLS.asignarVendedorPartial, data: { id: LEAD_ID }, size: 'md' });
    }

    function asignarVendedor() {
        const form = document.getElementById('formAsignarVendedor');
        const btn = document.getElementById('btnAsignarVendedor');
        const btnOriginal = btn.innerHTML;
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const data = { leadId: LEAD_ID, vendedorId: $('#VendedorId').val() };
        $.ajax({
            url: URLS.asignarVendedor, type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            beforeSend: () => $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>'),
            success: r => { if (r.success) { AppModal.close(); Toast.success('Vendedor asignado'); location.reload(); } else Toast.error(r.message); },
            error: xhr => Toast.error(xhr.responseJSON?.message || 'Error'),
            complete: () => $(btn).prop('disabled', false).html(btnOriginal)
        });
    }
</script>
}
