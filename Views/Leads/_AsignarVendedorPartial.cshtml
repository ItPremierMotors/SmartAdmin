@model SmartAdmin.Models.Crm.AsignarVendedorLeadViewModel
<form id="formAsignarVendedor">
    <input type="hidden" id="AsignarLeadId" value="@Model.LeadId" />
    <div class="mb-3">
        <label class="form-label">Vendedor <span class="text-danger">*</span></label>
        <select class="form-select" id="VendedorId" required>
            <option value="">Seleccione un vendedor...</option>
        </select>
    </div>
    <hr />
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" onclick="AppModal.close()">Cancelar</button>
        <button type="button" class="btn btn-warning" id="btnAsignarVendedor" onclick="asignarVendedor()">
            <i class="fas fa-user-plus me-1"></i> Asignar
        </button>
    </div>
</form>

<script>
    (function () {
        var sucursalId = '@Model.SucursalId';

        if (sucursalId && sucursalId !== '') {
            // Cargar solo vendedores asignados a la sucursal del lead
            $.get('@Url.Action("GetBySucursal", "VendedoresSucursal")', { sucursalId }, function (res) {
                if (res.success && res.data) {
                    res.data.forEach(v => $('#VendedorId').append(`<option value="${v.vendedorId}">${v.vendedorNombre}</option>`));
                }
                // Si no hay vendedores en la sucursal, cargar todos como fallback
                if (!res.data?.length) cargarTodosVendedores();
            });
        } else {
            // Sin sucursal, cargar todos
            cargarTodosVendedores();
        }

        function cargarTodosVendedores() {
            $.get('@Url.Action("GetVendedores", "Leads")', function (res) {
                if (res.success && res.data) {
                    res.data.forEach(u => $('#VendedorId').append(`<option value="${u.id}">${u.nombreCompleto}</option>`));
                }
            });
        }
    })();
</script>
