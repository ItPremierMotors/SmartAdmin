@model SmartAdmin.Models.Vehiculo.ProcesarEntregaViewModel

@{
    var vehiculoInfo = ViewBag.VehiculoInfo as string;
    var clienteNombre = ViewBag.ClienteNombre as string;
    var fechaMaximaEntrega = ViewBag.FechaMaximaEntrega as DateTime?;
}

<div class="alert alert-info">
    <i class="fas fa-info-circle me-1"></i>
    Al confirmar, el vehículo pasará a estado <strong>Entregado</strong> y se registrará la fecha de entrega automáticamente.
</div>

@if (!string.IsNullOrEmpty(vehiculoInfo))
{
    <div class="mb-3">
        <label class="form-label text-muted small">Vehículo</label>
        <div class="form-control-plaintext fw-bold">@vehiculoInfo</div>
    </div>
}

@if (!string.IsNullOrEmpty(clienteNombre))
{
    <div class="mb-3">
        <label class="form-label text-muted small">Cliente</label>
        <div class="form-control-plaintext">@clienteNombre</div>
    </div>
}

@if (fechaMaximaEntrega.HasValue)
{
    var hoy = DateTime.Today;
    var diasRestantes = (fechaMaximaEntrega.Value.Date - hoy).Days;
    var claseAlerta = diasRestantes < 0 ? "alert-danger" : diasRestantes <= 3 ? "alert-warning" : "alert-success";
    var textoEstado = diasRestantes < 0 ? $"Vencido hace {Math.Abs(diasRestantes)} día(s)" :
                      diasRestantes == 0 ? "Hoy es la fecha límite" :
                      $"{diasRestantes} día(s) restante(s)";

    <div class="alert @claseAlerta">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-calendar-check me-1"></i>
                <strong>Fecha límite:</strong> @fechaMaximaEntrega.Value.ToString("dd/MM/yyyy")
            </div>
            <span class="badge @(diasRestantes < 0 ? "bg-danger" : diasRestantes <= 3 ? "bg-warning text-dark" : "bg-success")">
                @textoEstado
            </span>
        </div>
    </div>
}

<input type="hidden" id="EntregaVehiculoId" value="@Model.VehiculoId" />

<div class="text-center py-2">
    <i class="fas fa-truck fa-3x text-muted mb-2"></i>
    <p class="text-muted">¿Confirmar la entrega de este vehículo?</p>
</div>

<div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i> Cancelar
    </button>
    <button type="button" class="btn btn-dark" id="btnProcesarEntrega" onclick="confirmarProcesarEntrega()">
        <i class="fas fa-truck me-1"></i> Confirmar Entrega
    </button>
</div>
