@{
    ViewBag.Title = "Inicio";
}

<div class="d-flex align-items-end mb-4">
    <div>
        @await Html.PartialAsync("~/Views/Shared/Partials/_PageTitle.cshtml", new {
            pageTitle = "Bienvenido",
            pageSubTitle1 = "PremierFlow",
            pageSubTitle2 = "Inicio",
            pageSubText = (string?)null
        })
    </div>
</div>

<div class="row justify-content-center mt-5">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fas fa-car-side fa-3x text-primary mb-3"></i>
                <h3 class="fw-bold">Bienvenido a PremierFlow</h3>
                <p class="text-muted mb-4">
                    Utiliza el menú lateral para navegar a los módulos a los que tienes acceso.
                </p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    @if (User.TienePermiso("Vehiculo.Ver"))
                    {
                        <a href="@Url.Action("Index", "Inventario")" class="btn btn-outline-primary">
                            <i class="fas fa-warehouse me-1"></i> Inventario
                        </a>
                    }
                    @if (User.TienePermiso("Venta.Ver"))
                    {
                        <a href="@Url.Action("Index", "Ventas")" class="btn btn-outline-success">
                            <i class="fas fa-handshake me-1"></i> Ventas
                        </a>
                    }
                    @if (User.TienePermiso("OrdenServicio.Ver"))
                    {
                        <a href="@Url.Action("Index", "OrdenServicio")" class="btn btn-outline-warning">
                            <i class="fas fa-tools me-1"></i> Taller
                        </a>
                    }
                    @if (User.TienePermiso("Recepcion.Ver"))
                    {
                        <a href="@Url.Action("Index", "Recepcion")" class="btn btn-outline-info">
                            <i class="fas fa-clipboard-check me-1"></i> Recepción
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>